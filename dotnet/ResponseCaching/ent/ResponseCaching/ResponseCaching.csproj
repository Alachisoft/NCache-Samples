<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>53afd1ca-887f-4c49-8a65-7f03d200608b</UserSecretsId>
	<UseWindowsThreadPool>true</UseWindowsThreadPool>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AspNetCore.ResponseCache.NCache" Version="5.3.6.1" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="9.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="9.0.10">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.VisualStudio.Web.CodeGeneration.Design" Version="9.0.0" />
    <PackageReference Include="System.Data.SqlClient" Version="4.9.0" />
	<Compile Remove="NCacheTagHelper\**" />
    <Content Remove="NCacheTagHelper\**" />
    <EmbeddedResource Remove="NCacheTagHelper\**" />
    <None Remove="NCacheTagHelper\**" />	  
  </ItemGroup>


</Project>
