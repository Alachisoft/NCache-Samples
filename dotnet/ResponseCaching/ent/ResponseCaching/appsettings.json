{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"NCacheSettings": {
		"CacheName": "demoCache",
		"DefaultConnectionStringName": "DemoDBServer",
		"EnableSqlDependency": true,
		"SqlDependencySettings": {
			"DatabaseName": "ResponseCaching",
			"TableName": "dbo.Products"
		}
	},
	"ConnectionStrings": {
		"DemoDBServer": "<db-conn-string>"
	}
}
