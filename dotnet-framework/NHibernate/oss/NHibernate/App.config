    <oracle.manageddataaccess.client>
        <version number="*">
            <dataSources>
                <dataSource alias="SampleDataSource" descriptor="(DESCRIPTION=(ADDRESS=(PROTOCOL=tcp)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL))) " />
            </dataSources>
        </version>
    </oracle.manageddataaccess.client>
    <appSettings>
        
        <!-- Replace db-conn-string with your database connection string. -->
        <add key="ConnectionString" value="Data Source=localhost\SQLEXPRESS;Initial Catalog=NHibernate;User ID=sa;Password=4Islamabad;Connect Timeout=30;Encrypt=False;TrustServerCertificate=True;" />
		<add key="ncache.application_id" value="myapp" />

	</appSettings>
